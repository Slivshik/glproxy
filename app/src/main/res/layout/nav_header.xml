<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="160dp"
    android:background="@color/colorPrimary"
    android:gravity="bottom"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="24dp"
    android:paddingBottom="18dp">

    <!-- Accent bar -->
    <View
        android:layout_width="32dp"
        android:layout_height="3dp"
        android:background="@color/colorAccent"
        android:layout_marginBottom="14dp" />

    <!-- Logo row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/img_wlrus_logo"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@mipmap/ic_launcher"
            android:contentDescription="WLRUS" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WLRUS"
                android:textColor="@color/colorAccent"
                android:textSize="20sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:fontFamily="@font/montserrat_thin" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VPN Client"
                android:textColor="@color/colorTextSecondary"
                android:textSize="11sp"
                android:layout_marginTop="1dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Beginner mode badge + toggle -->
    <LinearLayout
        android:id="@+id/layoutBeginnerToggle"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="14dp"
        android:background="@drawable/setup_card_default"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:id="@+id/tvBeginnerBadge"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/beginner_mode_title"
            android:textColor="@color/colorAccent"
            android:textSize="12sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchBeginnerNav"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="false"
            android:thumbTint="@color/colorAccent"
            android:trackTint="@color/colorItemDivider"
            android:clickable="false"
            android:focusable="false" />

    </LinearLayout>

</LinearLayout>
