<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape>
            <solid android:color="#1A00D4FF" />
            <stroke android:width="1.5dp" android:color="#00D4FF" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#15003060" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="#0D1A30" />
        </shape>
    </item>
</selector>
