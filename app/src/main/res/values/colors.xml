<?xml version="1.0" encoding="utf-8"?>
<!--
    WLRUS Color Palette
    Design: Deep dark navy + electric cyan accent. Clean, modern, trustworthy.
    To change the accent color, modify colorAccent and colorPrimary.
-->
<resources>
    <!-- Primary brand colors -->
    <color name="colorPrimary">#0A1628</color>
    <color name="colorPrimaryDark">#060E1C</color>
    <color name="colorPrimaryVariant">#0F1F3D</color>
    <color name="colorAccent">#00D4FF</color>
    <color name="colorAccentDark">#0099CC</color>

    <!-- Background hierarchy -->
    <color name="colorBackground">#080F1E</color>
    <color name="colorSurface">#0D1A30</color>
    <color name="colorSurfaceVariant">#132040</color>
    <color name="colorCardBackground">#0F1E35</color>

    <!-- Text -->
    <color name="colorOnPrimary">#FFFFFF</color>
    <color name="colorOnBackground">#E8EDF5</color>
    <color name="colorOnSurface">#CDD5E0</color>
    <color name="colorTextSecondary">#7A8FA8</color>
    <color name="colorTextHint">#4A5E72</color>

    <!-- Status colors -->
    <color name="colorSuccess">#00E5A0</color>
    <color name="colorWarning">#FFB940</color>
    <color name="colorError">#FF4D6A</color>
    <color name="colorInfo">#00D4FF</color>

    <!-- VPN state indicators -->
    <color name="colorConnected">#00E5A0</color>
    <color name="colorConnecting">#FFB940</color>
    <color name="colorDisconnected">#FF4D6A</color>
    <color name="colorIdle">#4A5E72</color>

    <!-- Server list item -->
    <color name="colorItemBackground">#0D1A30</color>
    <color name="colorItemBackgroundSelected">#142440</color>
    <color name="colorItemDivider">#1A2D4A</color>
    <color name="colorItemPing">#00D4FF</color>

    <!-- Drawer / sidebar -->
    <color name="colorDrawerBackground">#080F1E</color>
    <color name="colorDrawerItemActive">#142440</color>

    <!-- Buttons -->
    <color name="colorButtonPrimary">#00D4FF</color>
    <color name="colorButtonSecondary">#132040</color>
    <color name="colorFab">#00D4FF</color>
    <color name="colorFabIcon">#060E1C</color>

    <!-- Miscellaneous -->
    <color name="colorDivider">#1A2D4A</color>
    <color name="colorRipple">#1A00D4FF</color>
    <color name="colorHighlight">#00D4FF</color>
    <color name="colorShadow">#80000000</color>

    <!-- Legacy / compat (keep for existing references) -->
    <color name="ic_launcher_background">#0A1628</color>
    <color name="colorPingRed">#FF4444</color>
    <color name="colorPing">#00D4FF</color>
    <color name="colorIndicator">#00D4FF</color>
    <color name="color_fab_active">#00D4FF</color>
    <color name="color_fab_inactive">#888888</color>
</resources>
